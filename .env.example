# --- OpenAI Settings ---
OPENAI_API_KEY=sk---------------------------------
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=gpt-4o

# --- Neo4j Settings ---
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=supersecretadminpassword

# Read-Only user for LLM Agent execution
NEO4J_READONLY_USER=llm_reader
NEO4J_READONLY_PASSWORD=supersecretreadonlypassword

# --- Redis / Vector DB Settings ---
REDIS_URL=redis://redis_vector:6379

# --- LangSmith Observability ---
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=lsv2-------------------------------------
LANGCHAIN_PROJECT=graph-query-system

# --- Backend/Frontend Settings ---
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000



